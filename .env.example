# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real keys.

# Used by src/lib/gemini.ts (server-only) for Spyglass analysis.
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.5-flash if not set.
GEMINI_MODEL=

# Used by src/lib/firecrawl.ts (server-only) for URL page-text extraction.
FIRECRAWL_API_KEY=